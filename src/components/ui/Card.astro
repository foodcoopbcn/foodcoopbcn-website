---
interface Props {
  href?: string;
  class?: string;
}
const { href, class: className = '' } = Astro.props;
const cls = `group block bg-paper rounded-lg shadow-sm ring-1 ring-line overflow-hidden transition-shadow hover:shadow ${className}`;
const Tag = href ? 'a' : 'div';
---
<Tag class={cls} href={href}><slot /></Tag>
