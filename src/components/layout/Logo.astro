---
/* Placeholder wordmark. Replace with the real brand SVG/PNG in /public when available. */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<svg viewBox="0 0 220 40" class={className} role="img" aria-label="FoodCoop BCN">
  <g fill="none">
    <circle cx="20" cy="20" r="18" fill="var(--color-brand)" />
    <path
      d="M13 24c0-6 4-10 10-10-1 6-4 10-10 10Z"
      fill="var(--color-accent)"
    />
    <text
      x="46"
      y="20"
      font-family="var(--font-display)"
      font-weight="800"
      font-size="18"
      fill="var(--color-ink)"
      dominant-baseline="central"
      letter-spacing="-0.5"
    >FOODCOOP</text>
    <text
      x="46"
      y="33"
      font-family="var(--font-display)"
      font-weight="800"
      font-size="11"
      fill="var(--color-brand)"
      dominant-baseline="central"
      letter-spacing="3"
    >BARCELONA</text>
  </g>
</svg>
