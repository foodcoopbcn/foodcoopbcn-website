---
import { getLang, useTranslations, localizePath } from '../../i18n/utils';
import { org, social, hours, legalLinks } from '../../config/site';
import Newsletter from './Newsletter.astro';
import Icon from '../ui/Icon.astro';

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---
<footer class="mt-auto bg-ink text-paper">
  <div class="container-page grid gap-10 py-16 md:grid-cols-2 lg:grid-cols-4">
    <!-- Brand + newsletter -->
    <div class="lg:col-span-1">
      <p class="font-display text-2xl font-extrabold">FoodCoop<span class="text-accent">.</span></p>
      <p class="mt-3 max-w-xs text-sm text-paper/70">{t('footer.rights')}</p>
      <div class="mt-6">
        <p class="mb-2 text-sm font-bold uppercase tracking-wide text-accent">{t('footer.newsletter')}</p>
        <Newsletter />
      </div>
    </div>

    <!-- Hours -->
    <div>
      <h2 class="mb-4 flex items-center gap-2 text-sm font-bold uppercase tracking-wide text-accent">
        <Icon name="clock" size={16} /> {t('footer.hours')}
      </h2>
      <dl class="space-y-1.5 text-sm text-paper/80">
        {
          hours.map((h) => (
            <div class="flex justify-between gap-4">
              <dt>{h.day}</dt>
              <dd class="text-paper/60">{h.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <!-- Contact -->
    <div>
      <h2 class="mb-4 flex items-center gap-2 text-sm font-bold uppercase tracking-wide text-accent">
        <Icon name="pin" size={16} /> {t('footer.contact')}
      </h2>
      <address class="space-y-2 text-sm not-italic text-paper/80">
        <p>{org.address.street}<br />{org.address.postalCode} {org.address.locality}</p>
        <p><a href={`tel:${org.phone}`} class="hover:text-accent">{org.phoneDisplay}</a></p>
        <p><a href={`mailto:${org.email}`} class="hover:text-accent">{org.email}</a></p>
        <p><a href={org.mapUrl} class="hover:text-accent" target="_blank" rel="noopener">Google Maps ↗</a></p>
      </address>
      <div class="mt-5">
        <p class="mb-2 text-sm font-bold uppercase tracking-wide text-accent">{t('footer.follow')}</p>
        <div class="flex gap-2">
          {
            social.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener"
                aria-label={s.name}
                class="grid h-10 w-10 place-items-center rounded-full bg-paper/10 hover:bg-brand"
              >
                <Icon name={s.icon as any} size={18} />
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Documentation / legal -->
    <div>
      <h2 class="mb-4 text-sm font-bold uppercase tracking-wide text-accent">{t('footer.legal')}</h2>
      <ul class="space-y-2 text-sm text-paper/80">
        {
          legalLinks.map((l) => (
            <li>
              <a href={localizePath(l.path, lang)} class="hover:text-accent">
                {l.label[lang]}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="border-t border-paper/10">
    <div class="container-page flex flex-col items-center justify-between gap-2 py-5 text-xs text-paper/50 sm:flex-row">
      <p>© {year} {org.legalName}</p>
      <p>Fet amb ♥ a Barcelona · Allotjat sense traçadors</p>
    </div>
  </div>
</footer>
