---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  tone?: 'green' | 'soft';
}
const { eyebrow, title, intro, tone = 'green' } = Astro.props;
const bg = tone === 'green' ? 'bg-paper-green' : 'bg-paper-soft';
---
<section class={bg}>
  <div class="container-page pb-14 pt-20 md:pb-20 md:pt-24">
    {eyebrow && <p class="mb-3 text-sm font-bold uppercase tracking-widest text-brand">{eyebrow}</p>}
    <h1 class="max-w-3xl text-3xl text-ink">{title}</h1>
    {intro && <p class="mt-5 max-w-2xl text-lg text-ink-soft">{intro}</p>}
  </div>
</section>
